# ─────────────────────────────────────────────────────────────
# Slidedrain — environment variables
# ─────────────────────────────────────────────────────────────
# Kopier til .env.local for lokal utvikling og legg inn i Vercel
# (Project → Settings → Environment Variables) for prod og preview.
# Variabler prefiksert med NEXT_PUBLIC_ sendes til klient — alle
# andre er server-only.

# ─── Site ─────────────────────────────────────────────────────
# Bru for absolutte URLer i e-poster og metadata
NEXT_PUBLIC_SITE_URL=https://slidedrain.no

# ─── Resend (e-post) ──────────────────────────────────────────
# API-nøkkel fra https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxx
# Verifisert avsender, f.eks. "Slidedrain <post@slidedrain.no>"
# Domenet må være verifisert i Resend (DKIM + SPF i DNS)
RESEND_FROM_EMAIL=Slidedrain <post@slidedrain.no>
# Mottaker for skjema-innsendinger
RESEND_INTERNAL_NOTIFY_EMAIL=post@slidedrain.no

# ─── Google Tag Manager (anbefalt: ALL tracking gjennom GTM) ─
# Container ID, f.eks. GTM-XXXXXXX
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# ─── Meta Pixel (valgfritt — kan også lastes via GTM) ────────
# Sett denne KUN hvis du vil laste Meta Pixel direkte. Anbefalt
# er å la GTM håndtere det og la denne stå tom.
NEXT_PUBLIC_META_PIXEL_ID=

# ─── GA4 og Google Ads ──────────────────────────────────────
# Disse konfigureres INNE I GTM-containeren, ikke som env-vars.
# I GTM legger du til:
#   - GA4 Configuration Tag med Measurement ID (G-XXXXXXXXXX)
#   - Google Ads Conversion Tracking tag med Conversion ID + Label
#   - Meta Pixel som Custom HTML Tag (hvis ikke direkte over)
# Alle gates på Consent Mode kategorier:
#   - GA4   → analytics_storage = granted
#   - Meta  → ad_storage = granted
#   - Ads   → ad_storage = granted
